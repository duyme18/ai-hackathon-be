{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(bun install)",
      "Bash(bun run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log --oneline -n *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  }
}
